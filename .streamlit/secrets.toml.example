# Streamlit Cloud Secrets Configuration
# Add these in Streamlit Cloud dashboard → App Settings → Secrets
# Or save as .streamlit/secrets.toml for local development
#
# Choose ONE backend mode (GitHub Actions or Remote API):

# ── Option 1: GitHub Actions (零成本, 推荐) ─────────────────
# Create a PAT at https://github.com/settings/tokens with `actions` scope
GITHUB_TOKEN = "ghp_your_personal_access_token"
GITHUB_REPO = "your-username/scrape-hub"
GITHUB_BRANCH = "main"

# ── Option 2: Remote API Backend ────────────────────────────
# URL of your self-hosted API server (if you have a VPS)
# SCRAPE_HUB_API_URL = "https://your-api-server.com:8000"
# SCRAPE_HUB_API_SECRET = "change-me-to-a-strong-secret"
